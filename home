        }

        .testimonial-card p {
            font-style: italic;
            margin-bottom: 16px;
            line-height: 1.6;
        }

        .customer {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .customer-avatar {
            width: 48px;
            height: 48px;
            background: var(--primary-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
        }

        /* Footer */
        .footer {
            background: var(--gray-800);
            color: white;
            padding: 48px 0 24px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 48px;
            margin-bottom: 48px;
